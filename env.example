# ────────────────────────────────────────────────────────────────────
# Indian Railways RAG — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# ────────────────────────────────────────────────────────────────────

# ── API server ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8090

# ── JWT ──────────────────────────────────────────────────────────────
# Optional. If omitted, the hardcoded default in config.py is used.
# For production-grade security, uncomment and set a strong random secret:
# JWT_SECRET=<run: openssl rand -hex 32>
JWT_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────────────
# Local dev (native, no Docker):
DATABASE_URL=sqlite:///./data/ir_rag.db
# VM / Docker container (uses named volume at /data/sqlite):
# DATABASE_URL=sqlite:////data/sqlite/ir_rag.db

# ── Qdrant ───────────────────────────────────────────────────────────
# Local dev (Qdrant running directly on this machine):
# QDRANT_URL=http://127.0.0.1:6333

# VM Docker container — use host.docker.internal to reach the host's Qdrant:
QDRANT_URL=http://host.docker.internal:6333

# Qdrant API key — leave empty if your instance has no auth
QDRANT_API_KEY=

QDRANT_COLLECTION=ir_chunks

# ── Ollama ───────────────────────────────────────────────────────────
# Local dev (Ollama running directly on this machine):
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# VM Docker container — use host.docker.internal to reach the host's Ollama:
OLLAMA_BASE_URL=http://host.docker.internal:11434

OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG / Chunking ───────────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=50
# Top-K chunks sent to the LLM as context. Lower = faster generation on CPU.
# 5 is a good balance between answer quality and latency on CPU-only deployments.
RAG_TOP_K=5

# ── Agentic chunking ─────────────────────────────────────────────────
# Hard ceiling per chunk (chars) before a forced split
MAX_AGENTIC_CHUNK_CHARS=3000
# Upload timeout (seconds) — increase for large docs (20 min recommended)
UPLOAD_TIMEOUT_SECS=1200

# ── CORS (comma-separated origins) ───────────────────────────────────
# Local dev with Vite:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8090
# VM production — add your VM's IP or hostname:
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8090,http://YOUR_VM_IP:8090

# ── Admin seed (used only on first startup to create the admin user) ─
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=Admin@123

# ── Regular user seed ─────────────────────────────────────────────────
USER_SEED_USERNAME=user
USER_SEED_PASSWORD=User@123
